#!/usr/bin/env bash
# collect — wrapper for stock_collector.py
# Place this file in ~/bin (or any directory on $PATH).
# The Python scripts are expected in STOCK_DIR (edit below or set the
# environment variable before calling: STOCK_DIR=/other/path collect -s AAPL).

set -euo pipefail

# ── configuration ─────────────────────────────────────────────────────────────

# Directory where stock_collector.py lives and where data is stored.
# Priority: environment variable > value below.
STOCK_DIR="${STOCK_DIR:-$HOME/stock}"

# Python interpreter to use.
# Priority: environment variable > venv inside STOCK_DIR > system python3.
if [[ -x "$STOCK_DIR/.venv/bin/python" ]]; then
    PYTHON="$STOCK_DIR/.venv/bin/python"
elif [[ -n "${VIRTUAL_ENV:-}" ]]; then
    PYTHON="$VIRTUAL_ENV/bin/python"
else
    PYTHON="${PYTHON:-python3}"
fi

# ── checks ────────────────────────────────────────────────────────────────────

if [[ ! -d "$STOCK_DIR" ]]; then
    echo "collect: STOCK_DIR not found: $STOCK_DIR" >&2
    echo "  Set the STOCK_DIR environment variable or edit this script." >&2
    exit 1
fi

if ! "$PYTHON" -c "import sys; assert sys.version_info >= (3,10)" 2>/dev/null; then
    echo "collect: Python 3.10+ required. Found: $("$PYTHON" --version 2>&1)" >&2
    exit 1
fi

# ── run ───────────────────────────────────────────────────────────────────────

# Raise the open-file-descriptor limit to avoid OSError on long collection runs.
# macOS default is 256 which is too low when many API sources run in sequence.
ulimit -n 1024 2>/dev/null || true

cd "$STOCK_DIR"
exec "$PYTHON" -m stock_toolkit.collector "$@"
