# ─── databases ────────────────────────────────
*.db
*.db-shm
*.db-wal

# ─── CSV exports and runtime files ────────────
stock_data.csv
logs/
.collector_state.json
.alerts_state.json

# ─── config — contains API keys ───────────────
# covers config.env and local backups (config.env_key, config.env_keys, …)
config.env*

# ─── shell history snapshots ──────────────────
hist.*
hists/

# ─── runtime failure reports ──────────────────
stock_failures*.csv

# ─── packaged releases ────────────────────────
# Per-version archives now land in dist-bundles/ (see make_dist.py).
# Top-level patterns retained for old artifacts that pre-date the move.
dist-bundles/
stock-toolkit-*.tar.gz
stock-toolkit-*.zip
stock-app-*.tar.gz
stock-app-*.zip

# ─── generated plot output ────────────────────
gnuplot-data/
matplot/
data/

# ─── generated docs (make_docs.py) ────────────
docs/

# ─── distribution output ─────────────────────
dist/

# ─── Python ───────────────────────────────────
*.egg-info/
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.env

# ─── macOS ────────────────────────────────────
.DS_Store
.coverage
