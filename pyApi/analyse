#!/usr/bin/env bash
# analyse — wrapper for stock_analysis.py
# Place this file in ~/bin (or any directory on $PATH).

set -euo pipefail

STOCK_DIR="${STOCK_DIR:-$HOME/stock}"

if [[ -x "$STOCK_DIR/.venv/bin/python" ]]; then
    PYTHON="$STOCK_DIR/.venv/bin/python"
elif [[ -n "${VIRTUAL_ENV:-}" ]]; then
    PYTHON="$VIRTUAL_ENV/bin/python"
else
    PYTHON="${PYTHON:-python3}"
fi

if [[ ! -d "$STOCK_DIR" ]]; then
    echo "analyse: STOCK_DIR not found: $STOCK_DIR" >&2
    echo "  Set the STOCK_DIR environment variable or edit this script." >&2
    exit 1
fi

if ! "$PYTHON" -c "import sys; assert sys.version_info >= (3,10)" 2>/dev/null; then
    echo "analyse: Python 3.10+ required. Found: $("$PYTHON" --version 2>&1)" >&2
    exit 1
fi

if [[ ! -f "$STOCK_DIR/stock_analysis.py" ]]; then
    echo "analyse: stock_analysis.py not found in $STOCK_DIR" >&2
    exit 1
fi

cd "$STOCK_DIR"
exec "$PYTHON" stock_analysis.py "$@"
